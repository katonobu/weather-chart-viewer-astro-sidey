---
// src/pages/view/[id].astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "@components/common/Prose.astro";
import Glightbox from "@components/layout/Glightbox.astro";
import { TextToSpeechCtrl } from "@/components/TextToSpeechCtrl";
import {
  getDetailData,
  getStaticPathsByTargetId,
  getKaisetsu,
  CONTENTS_BASE_URL,
} from "../../utils/s3";

export async function getStaticPaths() {
  // 環境変数から ID を取得して生成
  const targetId = process.env.NEW_ENTRY_ID || "";
  return getStaticPathsByTargetId(targetId);
}

const { id } = Astro.params;
const data = await getDetailData(id!);

// 解説資料読み上げ用データ
const kaisetsuTexts = await getKaisetsu(id);
---

<BaseLayout title={data.title} , description={data.released_at_j}>
  <Prose>
    <div>
      <div class="weather-header">
        <h1 id="top">{data.title}</h1>
        <p class="release-date">{data.released_at_j}</p>
      </div>
      <a href="/recent" class="hover:underline inline-flex items-center gap-1">
        直近一週間
      </a>の目次へ
      <br />
      <a href="/archive" class="hover:underline inline-flex items-center gap-1">
        アーカイブ
      </a>の目次へ
      <br />
      <a href={`/details/${id}`}> データ詳細情報 </a>へ

      <h2>ページ内リンク</h2>
      <div>
        <ul class="list-disc text-wrap px-10">
          {
            data.files.map((file: any) => (
              <li>
                <a href={`#${file.id}`} class="hover:underline">
                  {file.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="weather-content">
        {
          data.files.map((file: any) => (
            <section id={file.id} class="weather-section">
              <a
                href={`${CONTENTS_BASE_URL}/${id}/${file.name}`}
                target="_blank"
                id={file.id}
              >
                <h2>{file.title}</h2>
                <svg
                  aria-hidden="true"
                  height="16"
                  viewBox="0 0 16 16"
                  version="1.1"
                  width="16"
                  data-view-component="true"
                >
                  <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z" />
                </svg>
              </a>

              <div class="w-full overflow-x-auto bg-white border border-gray-100">
                <img
                  src={`${CONTENTS_BASE_URL}/${id}/${file.name}`}
                  alt={file.title}
                  loading="lazy"
                  class="w-full h-auto"
                  data-glightbox="true"
                  data-title={file.title}
                />
              </div>
              <a href="#top" class="hover:underline">
                ページの先頭へ
              </a>
            </section>
          ))
        }
        <Glightbox />
      </div>

      <a href={`/details/${id}`}>データ詳細情報へ</a>
    </div>
  </Prose>

  <div
    slot="player"
    class="fixed inset-x-0 bottom-0 z-[100] bg-white border-t border-gray-200 p-4 shadow-lg"
  >
    <TextToSpeechCtrl texts={kaisetsuTexts} viewtext={true} client:load />
  </div>
</BaseLayout>

<style>
  .weather-header {
    margin-bottom: 2rem;
    border-bottom: 2px solid #333;
  }
  .release-date {
    font-weight: bold;
    color: #555;
  }
  .weather-section {
    margin-bottom: 3rem;
  }
  .image-wrapper {
    width: 100%;
    overflow-x: auto;
  }
  .image-wrapper img {
    max-width: 100%;
    height: auto;
  }
</style>