---
// src/pages/view/[id].astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "@components/common/Prose.astro";
import Photoswipe from "@components/layout/Photoswipe.astro"
import { TextToSpeechCtrl } from "@/components/TextToSpeechCtrl";
import {
  getDirectoryList,
  getDetailDataWithPxSize,
  getStaticPathsByTargetId,
  getKaisetsu,
  getContentsLinkUrl,
} from "../../utils/s3";

export async function getStaticPaths() {
  // 環境変数から ID を取得して生成
  const targetId = process.env.NEW_ENTRY_ID || "";
  return getStaticPathsByTargetId(targetId);
}


const { id } = Astro.params;
const data = await getDetailDataWithPxSize(id!);
const dirList = (await getDirectoryList()) || []
const currentIndex = dirList.indexOf(id)
const newerId = 0 < currentIndex ? dirList[currentIndex-1] : null
const olderId = currentIndex < dirList.length - 1 ? dirList[currentIndex+1] : null

// console.log(newerId, olderId)

// 解説資料読み上げ用データ
const kaisetsuTexts = await getKaisetsu(id);
const CONTENTS_LINK_URL = getContentsLinkUrl()
---

<BaseLayout title={data.title} , description={data.released_at_j}, addPaddingBottom={true}>
  <Prose>
    <div>
      <div>
        <h1 id="top">{data.title}</h1>
        <p>{data.released_at_j}</p>
      </div>
      <a href={`/view/${newerId}`}>
        {newerId?"＜＜":""}
      </a>
      <span> 前後のデータ </span>
      <a href={`/view/${olderId}`}>
        {olderId?"＞＞":""}
      </a>
      <h2>ページ内リンク</h2>
      <div>
        <ul>
          {
            data.files.map((file: any) => (
              <li>
                <a href={`#${file.id}`}>
                  {file.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <Photoswipe>
        <div>
          {
            data.files.map((file: any) => (
              <section id={file.id}>
                <a href={`${CONTENTS_LINK_URL}/${id}/${file.name}`} class="heading-link">
                  <h2>{file.title}</h2>
                  <svg aria-hidden="true" height="16" viewBox="0 0 16 16" version="1.1" width="16" data-view-component="true">
                    <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z" />
                  </svg>
                </a>

                <div class="flex items-center gap-2">
                  <a href={`/view/${newerId}#${file.id}`}>{newerId?"＜＜":""}</a>
                  <span> 前後のデータ </span>
                  <a href={`/view/${olderId}#${file.id}`}>{olderId?"＞＞":""}</a>
                </div>

                <div class="w-full overflow-x-auto bg-white border border-gray-100">
                  <a href={`${CONTENTS_LINK_URL}/${id}/${file.name}`}
                    class="pswp-link"
                    data-pswp-src={`${CONTENTS_LINK_URL}/${id}/${file.name}`}                  
                    data-pswp-width={file.width}
                    data-pswp-height={file.height}
                  >
                    <img
                      src={`${CONTENTS_LINK_URL}/${id}/${file.name}`}
                      alt={file.title} 
                      style={`aspect-ratio: ${file.width} / ${file.height};`}
                      class="block w-full"
                      loading="lazy"                      
                    />
                  </a>
                </div>

                <a href="#top">ページの先頭へ</a>
              </section>
            ))
          }
        </div>
      </Photoswipe>

      <h2>データ情報</h2>
      <a href="https://www.jma.go.jp/jma/index.html">
        気象庁ホームページ
      </a>のデータを加工して作成。
      <br />
      本サイトで引用している気象庁データの引用元URL及び加工方法詳細は
      <a href="/datafetch"> 出典情報 </a>参照。
      <br/>
      本ページで参照した加工元データ詳細は
      <a href={`/details/${id}`}> データ詳細情報 </a>参照。
    </div>
  </Prose>

  <div
    slot="player"
    class="fixed inset-x-0 bottom-0 z-[100] bg-white border-t border-gray-200 p-4 shadow-lg"
  >
    <TextToSpeechCtrl texts={kaisetsuTexts} viewtext={true} client:load />
  </div>
</BaseLayout>

<style>
  .heading-link {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }

  /* 他の h2 と同じ余白をそのまま使う */
  .heading-link h2 {
    margin-top: 40px;
    margin-bottom: 20px;
    line-height: 1.3;
  }

  /* SVG の位置を補正して中央揃えに見せる */
  .heading-link svg {
    display: block;
    margin-top: 40px;   /* h2 の margin-top と揃える */
    margin-bottom: 20px;/* h2 の margin-bottom と揃える */
  }
</style>
