---
// src/pages/view/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDetailData } from '../../utils/s3';

export async function getStaticPaths() {
  // 環境変数から ID を取得して生成（指定がない場合はビルドが空になる安全設計）
  const targetId = process.env.NEW_ENTRY_ID || "20260703_1540"
  if (targetId) {
    return [{ params: { id: targetId } }];
  }
  return [];
}

const { id } = Astro.params;
const data = await getDetailData(id!);

// S3のバケットURL（環境に合わせて変更してください）
const S3_BASE_URL = "https://d1xdqsn7je8bay.cloudfront.net/shared/services/weatherchart";
---

<BaseLayout title={data.title}, description={data.released_at_j}>
  <div class="weather-header">
    <h1>{data.title}</h1>
    <p class="release-date">{data.released_at_j}</p>
  </div>

  <div class="weather-content">
    {data.files.map((file: any) => (
      <section id={file.id} class="weather-section">
        <h2>{file.title}</h2>
        <div class="image-wrapper">
          <img 
            src={`${S3_BASE_URL}/${id}/${file.name}`} 
            alt={file.title} 
            loading="lazy" 
          />
        </div>
      </section>
    ))}
  </div>

  <footer class="weather-footer" style="margin-top: 3rem; border-top: 1px solid #ddd; padding-top: 1rem;">
    <a href={`/details/${id}`}>データ詳細情報へ</a>
  </footer>
</BaseLayout>

<style>
  .weather-header { margin-bottom: 2rem; border-bottom: 2px solid #333; }
  .release-date { font-weight: bold; color: #555; }
  .weather-section { margin-bottom: 3rem; }
  .image-wrapper { width: 100%; overflow-x: auto; }
  .image-wrapper img { max-width: 100%; height: auto; }
</style>