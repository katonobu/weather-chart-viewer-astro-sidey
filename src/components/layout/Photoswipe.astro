---
// src/components/layout/Photoswipe.astro
---
<style is:global>
  /* npm導入により、CSSもパス解決が楽になります */
  @import "photoswipe/style.css";
  @import 'photoswipe/dist/photoswipe.css';
  @import 'photoswipe-dynamic-caption-plugin/photoswipe-dynamic-caption-plugin.css';

  /* 1. モーダル背景（薄い黒） */
  .pswp { --pswp-bg: rgba(0, 0, 0, 0.8); }

  /* 2. 画像の背景を強制的に白くする (透過画像対策) */
  .pswp__zoom-wrap, .pswp__img {
    background-color: #ffffff !important;
  }

  /* 3. ギャラリーの見た目調整 */
  .pswp-gallery a.pswp-link {  
    cursor: zoom-in;
    display: block;
  }
</style>

<div class="pswp-gallery" id="my-gallery">
  <slot />
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import PhotoSwipe from 'photoswipe';
  import PhotoSwipeDynamicCaption from 'photoswipe-dynamic-caption-plugin';

  let lightbox: PhotoSwipeLightbox | null = null;

  const initGallery = () => {
    const galleryEl = document.querySelector('.pswp-gallery') as HTMLElement;
    if (!galleryEl) {
      console.log("No element")
      return
    }

    // 1. ここでライブラリを先に読み込んでおく（ブラウザのキャッシュに乗る）
    import('photoswipe');

    lightbox = new PhotoSwipeLightbox({
      gallery: '#my-gallery',
      children: 'a.pswp-link', // 「pswp-link」クラスを持つ<a>タグだけを対象にする        
      pswpModule: PhotoSwipe,
      wheelToZoom: true,
      allowPanToNext: true,
      preload: [0, 1], // 最初の1枚と次の1枚を事前にロードする      
    });
    const captionPlugin = new PhotoSwipeDynamicCaption(lightbox, {
      type: 'below', // 'auto', 'below', 'aside' から選択
    });

    lightbox.init();
  };

  // AstroのView Transitions対応
  document.addEventListener('astro:page-load', initGallery);
  document.addEventListener('astro:before-swap', () => {
    if (lightbox) {
      lightbox.destroy();
      lightbox = null;
    }
  });  
</script>