---
import { ClientRouter } from "astro:transitions"
import { config } from "@parseConfig"
import { isProductionEnv, envTarget} from "@utils/envUtil"

interface Props {
  title: string
  description: string
  image?: string
}

const { title: pageTitle, description: pageDescription, image } = Astro.props

const siteName = config.site.title
const isHome = Astro.url.pathname === "/"
const fullTitle = isHome
  ? siteName
  : pageTitle
    ? `${pageTitle} — ${siteName}`
    : siteName
const description = pageDescription || config.site.description
const socialImage = new URL(image || "/og-image.png", config.site.url)
const canonicalURL = new URL(Astro.url.pathname, config.site.url)

const titlePrefix = isProductionEnv ? "" : `${envTarget.toUpperCase()}+`
---

{/* Global Metadata */}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={config.site.author} />
<meta name="theme-color" content="#FFFCF0" />

{/* Canonical URL */}
<link rel="canonical" href={canonicalURL} />

{/* Primary Meta Tags */}
<title>{`${titlePrefix}${fullTitle}`}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<link rel="sitemap" href="/sitemap-index.xml" />

{/* Robots Control (本番のみインデックスを許可) */}
{isProductionEnv ? (
  <meta name="robots" content="index, follow" />
) : (
  <meta name="robots" content="noindex, nofollow" />
)}

{/* Open Graph / Facebook */}
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />

{/* Twitter */}
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImage} />

{/* Favicons */}
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link
  rel="icon"
  type="image/png"
  href="/favicons/favicon-96x96.png?v=20260714"
  sizes="96x96"
/>
<link rel="shortcut icon" href="/favicons/favicon.ico?v=20260714" />
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/favicons/apple-touch-icon.png?v=20260714"
/>

{/* App */}
<meta name="apple-mobile-web-app-title" content={siteName} />
<link rel="manifest" href="/favicons/site.webmanifest?v=20260714" />

{/* View Transition API */}
<ClientRouter />
